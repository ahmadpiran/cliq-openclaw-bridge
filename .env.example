# ── Server ──────────────────────────────────────────
PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=30s

# ── Bridge Internal ──────────────────────────────────
# Shared secret for POST /notify from OpenClaw hook
BRIDGE_NOTIFY_SECRET=replace_with_strong_random_secret

# ── Zoho Cliq ───────────────────────────────────────
ZOHO_WEBHOOK_SECRET=replace_with_zoho_webhook_secret
ZOHO_CLIENT_ID=replace_with_zoho_client_id
ZOHO_CLIENT_SECRET=replace_with_zoho_client_secret
ZOHO_REDIRECT_URI=https://your-domain.com/oauth/callback
ZOHO_TOKEN_KEY=zoho:default
ZOHO_REPLY_WEBHOOK_URL=https://cliq.zoho.com/api/v2/bots/yourbotname/message?zapikey=yourtoken

# ── OpenClaw AI Gateway ──────────────────────────────
OPENCLAW_BASE_URL=http://openclaw-gateway:18789
OPENCLAW_API_KEY=replace_with_openclaw_hooks_token
OPENCLAW_AGENTS_DIR=/data/openclaw/agents
OPENCLAW_WORKSPACE_DIR=/data/openclaw-workspace
OPENCLAW_MAX_RETRIES=4
OPENCLAW_INITIAL_BACKOFF=500ms
OPENCLAW_MAX_BACKOFF=30s
OPENCLAW_HTTP_TIMEOUT=15s
OPENCLAW_REPLY_TIMEOUT=120s

# ── Storage ──────────────────────────────────────────
BOLT_DB_PATH=/data/tokens.db

# ── Worker Pool ──────────────────────────────────────
WORKER_COUNT=8
WORKER_QUEUE_DEPTH=512
WORKER_JOB_TIMEOUT=150s