# ── Server ──────────────────────────────────────────
PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=30s

# ── Zoho Cliq ───────────────────────────────────────
# Shared secret configured in your Zoho Cliq webhook settings.
ZOHO_WEBHOOK_SECRET=replace_with_zoho_webhook_secret

# OAuth2 app credentials from console.zoho.com → API Console.
ZOHO_CLIENT_ID=replace_with_zoho_client_id
ZOHO_CLIENT_SECRET=replace_with_zoho_client_secret

# The exact redirect URI registered in your Zoho OAuth app.
ZOHO_REDIRECT_URI=https://your-domain.com/oauth/callback

ZOHO_CLIQ_API_URL=https://cliq.zoho.com
# Reply-back via Zoho webhook token — no OAuth needed
ZOHO_REPLY_WEBHOOK_URL=

# BoltDB key under which the token is stored. Default is fine for single-org setups.
ZOHO_TOKEN_KEY=zoho:default

# ── OpenClaw AI Gateway ──────────────────────────────
OPENCLAW_BASE_URL=https://api.openclaw.io/v1
OPENCLAW_API_KEY=replace_with_openclaw_api_key
OPENCLAW_AGENTS_DIR=/data/openclaw/agents
OPENCLAW_MAX_RETRIES=4
OPENCLAW_INITIAL_BACKOFF=500ms
OPENCLAW_MAX_BACKOFF=30s
OPENCLAW_HTTP_TIMEOUT=15s
OPENCLAW_REPLY_TIMEOUT=180s
OPENCLAW_WORKSPACE_DIR=/data/openclaw-workspace

# ── Storage ──────────────────────────────────────────
# Mount a persistent volume at this path in production.
BOLT_DB_PATH=/data/tokens.db

# ── Worker Pool ──────────────────────────────────────
WORKER_COUNT=8
WORKER_QUEUE_DEPTH=512
WORKER_JOB_TIMEOUT=210s